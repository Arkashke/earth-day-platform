APP_NAME="День Земли"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Moscow
APP_URL=http://localhost:8000

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=ru_RU

APP_BUFFER_OUTPUT=false

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=earth_day_db
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=file
CACHE_PREFIX=earthday_

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAILING_FROM_ADDRESS="noreply@earthday.ru"
MAILING_FROM_NAME="День Земли"

# === Платёжные агрегаторы ===
# ЮKassa
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_DEBUG=true

# CloudPayments
CLOUDPAYMENTS_PUBLIC_ID=
CLOUDPAYMENTS_SECRET_KEY=

# === Реквизиты для счетов ===
COMPANY_NAME="Оргкомитет проекта «День Земли — каждый день!»"
COMPANY_INN=7712345678
COMPANY_KPP=771201001
COMPANY_ADDRESS=г. Москва, ул. Примерная, д. 1
COMPANY_PHONE=+7 (495) 123-45-67
COMPANY_EMAIL=info@earthday.ru

# === reCAPTCHA v3 ===
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# === Яндекс.Карты ===
YANDEX_MAPS_API_KEY=

# === Yandex Object Storage (S3-совместимое) ===
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ru-central1
AWS_BUCKET=earth-day-storage
AWS_URL=https://storage.earthday.ru
AWS_ENDPOINT=https://storage.yandexcloud.net

# === UniSender / Sendinblue ===
MAILING_SERVICE_API_KEY=
MAILING_SERVICE_SENDER_EMAIL=noreply@earthday.ru
MAILING_SERVICE_SENDER_NAME="День Земли"

# === Slack Alerts ===
SLACK_WEBHOOK_URL=

# === AWS (альтернатива Yandex) ===
AWS_USE_PATH_STYLE_ENDPOINT=false
